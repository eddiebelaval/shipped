# Shipped. Pipeline — Environment Variables
# Copy to .env and fill in. Never commit .env.

# X (Twitter) MCP server — the PREFERRED source, tried before the X API.
# X_MCP_URL is the server's Streamable-HTTP endpoint; the token authenticates.
# If X_MCP_URL is unset, the scraper silently falls back to the X API below.
# X_MCP_URL=https://mcp.x.com/   (set to your X MCP server endpoint)
X_MCP_URL=
X_MCP_BEARER_TOKEN=
# Override the MCP tool names if X's server uses different ones.
# X_MCP_TIMELINE_TOOL=get_user_posts
# X_MCP_SEARCH_TOOL=search_posts

# X (Twitter) API v2 read-only Bearer Token — fallback after the X MCP.
# Get from: https://developer.x.com/en/portal/dashboard
# If both X MCP and this are missing, the scraper falls back to Nitter.
X_API_BEARER_TOKEN=

# Enrichment: the X MCP search sweep widens each feed with cross-lab / third-
# party posts so issues stop collapsing on quiet days (content/DAILY.md).
# The orchestrator runs it by default; set to "off" for timeline-only scrapes.
# SHIPPED_X_ENRICH=on

# Override deploy path. Default: ../../id8labs/public/shipped (relative to pipeline root)
# SHIPPED_DEPLOY_PATH=

# Override knowledge source path. Default: ../../knowledge/series/shipped
# SHIPPED_KNOWLEDGE_PATH=

# X scraper target. Default: claudedevs
# SHIPPED_SCRAPE_USERNAME=claudedevs

# Verifier strictness:
#   strict   = any failure blocks publish (default)
#   warn     = failures printed but pipeline continues (preview mode)
#   off      = skip verification entirely (DANGEROUS, dev only)
# SHIPPED_VERIFY_MODE=strict

# Concurrency for URL liveness checks. Default: 8
# SHIPPED_FETCH_CONCURRENCY=8

# Request timeout per fetch (ms). Default: 10000
# SHIPPED_FETCH_TIMEOUT_MS=10000
