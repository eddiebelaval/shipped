# Shipped. Pipeline — Environment Variables
# Copy to .env and fill in. Never commit .env.

# X (Twitter) API v2 read-only Bearer Token
# Get from: https://developer.x.com/en/portal/dashboard
# Required for the @claudedevs scraper. If missing, scraper falls back to Nitter.
X_API_BEARER_TOKEN=

# Override deploy path. Default: ../../id8labs/public/shipped (relative to pipeline root)
# SHIPPED_DEPLOY_PATH=

# Override knowledge source path. Default: ../../knowledge/series/shipped
# SHIPPED_KNOWLEDGE_PATH=

# X scraper target. Default: claudedevs
# SHIPPED_SCRAPE_USERNAME=claudedevs

# Verifier strictness:
#   strict   = any failure blocks publish (default)
#   warn     = failures printed but pipeline continues (preview mode)
#   off      = skip verification entirely (DANGEROUS, dev only)
# SHIPPED_VERIFY_MODE=strict

# Concurrency for URL liveness checks. Default: 8
# SHIPPED_FETCH_CONCURRENCY=8

# Request timeout per fetch (ms). Default: 10000
# SHIPPED_FETCH_TIMEOUT_MS=10000
